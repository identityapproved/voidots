#!/bin/sh

FG="dcd7ba"
MUTED="727169"
BLUE="7e9cd8"
YELLOW="c0a36e"
GREEN="98bb6c"
RED="c34043"

c() {
    printf '^fg(%s)%s^fg()' "$1" "$2"
}

sep() {
    c "$MUTED" " | "
}

get_net() {
    set -- $(ip -4 route get 1.1.1.1 2>/dev/null) || {
        printf "net down"
        return
    }

    iface="?"
    src="no-ip"

    while [ "$#" -gt 0 ]; do
        case "$1" in
            dev)
                shift
                iface="$1"
                ;;
            src)
                shift
                src="$1"
                ;;
        esac
        shift
    done

    case "$iface" in
        wg-*) printf "¾░Æā %s %s" "$iface" "$src" ;;
        *)    printf "¾░¢® %s %s" "$iface" "$src" ;;
    esac
}

get_vol() {
    out="$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)" || {
        printf "vol ?"
        return
    }

    case "$out" in
        *MUTED*) printf "¾░Ø¤ muted" ;;
        *)
            vol="$(printf '%s\n' "$out" | awk '{printf "%d%%", ($2 * 100) + 0.5}')"
            printf "’Ć© %s" "$vol"
            ;;
    esac
}

get_brightness() {
    base="/sys/class/backlight/intel_backlight"

    [ -r "$base/brightness" ] && [ -r "$base/max_brightness" ] || {
        printf "¾░ā× bri ?"
        return
    }

    cur="$(cat "$base/brightness")"
    max="$(cat "$base/max_brightness")"

    [ "$max" -gt 0 ] 2>/dev/null || {
        printf "¾░ā× bri ?"
        return
    }

    printf "¾░āĀ %d%%" "$((cur * 100 / max))"
}

get_battery() {
    bat="/sys/class/power_supply/BAT0"

    [ -d "$bat" ] || {
        printf "^fg(%s)¾░éæ bat ?^fg()" "$MUTED"
        return
    }

    cap="$(cat "$bat/capacity" 2>/dev/null)"
    status="$(cat "$bat/status" 2>/dev/null)"

    case "$status" in
        Charging)
            printf "^fg(%s)¾░éä %s%%^fg()" "$GREEN" "${cap:-?}" ;;
        Full)
            printf "^fg(%s)¾░ü╣ %s%%^fg()" "$GREEN" "${cap:-?}" ;;
        Discharging)
            if [ "${cap:-0}" -le 15 ]; then
                printf "^fg(%s)¾░ü║ %s%%^fg()" "$RED" "${cap:-?}"
            elif [ "${cap:-0}" -le 40 ]; then
                printf "^fg(%s)¾░ü╝ %s%%^fg()" "$YELLOW" "${cap:-?}"
            else
                printf "^fg(%s)¾░ü╣ %s%%^fg()" "$BLUE" "${cap:-?}"
            fi ;;
        *)
            printf "^fg(%s)¾░éæ %s%%^fg()" "$MUTED" "${cap:-?}" ;;
    esac
}

get_power() {
    cache="$HOME/.cache/current-tlp-profile"

    if [ -r "$cache" ]; then
        profile="$(cat "$cache")"
    else
        profile=""
    fi

    if [ -n "$profile" ] && [ "$profile" != "tlp ?" ]; then
        case "$profile" in
            performance/AC) printf "^fg(%s)¾░ōģ perf AC^fg()" "$RED" ;;
            balanced/AC)    printf "^fg(%s)¾░Šģ bal AC^fg()" "$BLUE" ;;
            powersave/BAT)  printf "^fg(%s)¾░Šå save BAT^fg()" "$YELLOW" ;;
            */AC)           printf "^fg(%s)¾░Üź %s^fg()" "$BLUE" "$profile" ;;
            */BAT)          printf "^fg(%s)¾░ü╣ %s^fg()" "$YELLOW" "$profile" ;;
            *)              printf "^fg(%s)¾░Šģ %s^fg()" "$MUTED" "$profile" ;;
        esac
        return
    fi

    # fallback: cheap power-source detection
    for ac in /sys/class/power_supply/AC* /sys/class/power_supply/ADP* /sys/class/power_supply/ACAD* /sys/class/power_supply/MAINS*; do
        [ -r "$ac/online" ] || continue

        if [ "$(cat "$ac/online" 2>/dev/null)" = "1" ]; then
            printf "^fg(%s)¾░Üź AC^fg()" "$BLUE"
        else
            printf "^fg(%s)¾░ü╣ BAT^fg()" "$YELLOW"
        fi

        return
    done

    printf "^fg(%s)¾░Šģ tlp ?^fg()" "$MUTED"
}

printf '%s%s%s%s%s%s%s%s%s%s%s\n' \
    "$(c "$BLUE"   "$(get_net)")" \
    "$(sep)" \
    "$(c "$BLUE"   "$(get_vol)")" \
    "$(sep)" \
    "$(c "$YELLOW" "$(get_brightness)")" \
    "$(sep)" \
    "$(get_battery)" \
    "$(sep)" \
    "$(get_power)" \
    "$(sep)" \
    "$(c "$FG"     "$(date '+%H:%M')")"
